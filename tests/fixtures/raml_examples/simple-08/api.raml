#%RAML 0.8
title: Simple User API
version: v1
baseUri: https://api.example.com/{version}
mediaType: application/json
protocols: [ HTTPS ]

documentation:
  - title: Overview
    content: |
      A simple RAML 0.8 API for managing users.

schemas:
  - User: |
      {
        "$schema": "http://json-schema.org/draft-04/schema#",
        "type": "object",
        "required": ["id", "name", "email"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "active": { "type": "boolean" }
        }
      }
  - NewUser: |
      {
        "$schema": "http://json-schema.org/draft-04/schema#",
        "type": "object",
        "required": ["name", "email"],
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string" },
          "active": { "type": "boolean" }
        }
      }

/users:
  get:
    description: List users
    queryParameters:
      limit:
        type: integer
        required: false
        default: 20
        minimum: 1
        maximum: 100
      active:
        type: boolean
        required: false
    responses:
      200:
        body:
          application/json:
            schema: User[]
  post:
    description: Create a user
    body:
      application/json:
        schema: NewUser
    responses:
      201:
        body:
          application/json:
            schema: User

/users/{userId}:
  uriParameters:
    userId:
      type: integer
      required: true
      minimum: 1
  get:
    description: Fetch one user by ID
    responses:
      200:
        body:
          application/json:
            schema: User
      404:
        body:
          application/json:
            example: |
              {
                "message": "User not found"
              }
