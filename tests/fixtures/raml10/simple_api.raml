#%RAML 1.0
title: Simple API
version: v1
baseUri: http://api.example.com/{version}
mediaType: application/json

types:
  User:
    type: object
    properties:
      id: integer
      name: string
      email: string

/users:
  get:
    queryParameters:
      limit:
        type: integer
        default: 10
        minimum: 1
        maximum: 100
    responses:
      200:
        body:
          application/json:
            type: User[]
            example:
              - id: 1
                name: John
  
  /{id}:
    get:
      uriParameters:
        id:
          type: integer
          required: true
      responses:
        200:
          body:
            application/json:
              type: User
